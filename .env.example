# MongoDB
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
DATABASE_NAME=Test

# OpenAI (optional — improves extraction accuracy)
OPENAI_API_KEY=sk-...

# File storage
UPLOAD_DIR=./uploads

# SMTP (required for password reset emails)
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Frontend URL (used in password reset email link — must be reachable from email client)
# For local dev:  http://localhost:5173
# For mobile/network: http://192.168.x.x:5173
# For production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173
